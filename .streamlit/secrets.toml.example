# Copy this to .streamlit/secrets.toml and fill in values.
# .streamlit/ is in .gitignore — secrets.toml will NOT be committed.

# --- API Keys ---
FMP_API_KEY = ""
FINNHUB_API_KEY = ""
FRED_API_KEY = ""
ANTHROPIC_API_KEY = ""
SIMFIN_API_KEY = ""

# --- Firebase (client-side) ---
FIREBASE_API_KEY = ""
FIREBASE_PROJECT_ID = ""
FIREBASE_AUTH_DOMAIN = ""

# --- Firebase Service Account (server-side) ---
[firebase_service_account]
type = "service_account"
project_id = ""
private_key_id = ""
private_key = ""
client_email = ""
client_id = ""
auth_uri = ""
token_uri = ""
auth_provider_x509_cert_url = ""
client_x509_cert_url = ""
universe_domain = ""
